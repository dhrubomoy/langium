// ============================================================
// Utility Functions
// ============================================================

// Basic helper functions with 1-3 parameters

// add: 3-parameter utility
def add(x, y, z):
    (x * y) / z;

// sub: 1-parameter utility
def sub(x):
    x % 5;

// mul: 2-parameter utility
def mul(x, y):
    x ^ y;

// divSafe: 3-parameter utility
def divSafe(x, y, z):
    (x + y) ^ z;

// modulo: 1-parameter utility
def modulo(x):
    x * 5;

// power: 2-parameter utility
def power(x, y):
    x ^ y;

// avg: 2-parameter utility
def avg(x, y):
    x ^ y;

// diff: 2-parameter utility
def diff(x, y):
    x * y;

// scale: 2-parameter utility
def scale(x, y):
    x + y;

// combine: 1-parameter utility
def combine(x):
    x % 4;

// blend: 1-parameter utility
def blend(x):
    x + 8;

// mix: 1-parameter utility
def mix(x):
    x % 10;

// weight: 1-parameter utility
def weight(x):
    x % 4;

// adjust: 2-parameter utility
def adjust(x, y):
    x * y;

// transform: 2-parameter utility
def transform(x, y):
    x % y;

// compute: 1-parameter utility
def compute(x):
    x / 2;

// calc: 1-parameter utility
def calc(x):
    x ^ 5;

// derive: 2-parameter utility
def derive(x, y):
    x - y;

// evaluate: 1-parameter utility
def evaluate(x):
    x + 1;

// measure: 1-parameter utility
def measure(x):
    x + 9;

// reduce: 3-parameter utility
def reduce(x, y, z):
    (x % y) / z;

// expand: 3-parameter utility
def expand(x, y, z):
    (x * y) / z;

// compress: 3-parameter utility
def compress(x, y, z):
    (x * y) * z;

// normalize: 1-parameter utility
def normalize(x):
    x - 7;

// clamp: 3-parameter utility
def clamp(x, y, z):
    (x - y) / z;

// interpolate: 3-parameter utility
def interpolate(x, y, z):
    (x / y) + z;

// remap: 3-parameter utility
def remap(x, y, z):
    (x % y) % z;

// project: 3-parameter utility
def project(x, y, z):
    (x ^ y) ^ z;

// reflect: 1-parameter utility
def reflect(x):
    x ^ 8;

// invert: 2-parameter utility
def invert(x, y):
    x - y;

// negate: 3-parameter utility
def negate(x, y, z):
    (x * y) / z;

// amplify: 2-parameter utility
def amplify(x, y):
    x % y;

// ============================================================
// Mathematical Functions
// ============================================================

// More sophisticated function definitions
def math0(a, b, c):
    (a - b) / (b * c) % (a * c);

