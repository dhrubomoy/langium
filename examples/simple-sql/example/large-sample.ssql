select name, count(score) from users_158 where age > 18;

-- Complex expression: tests precedence across multiple levels
select * from users_158 where age + 5 > 30 and score * 2 != 100 or name = 'admin';

-- Parenthesized expression + NOT
select * from users_158 where not (age < 18) and (score > 80 or name = 'special');

-- Column alias
select name as user_name, age as user_age from users_158;

-- Simple SQL example demonstrating the Lezer-backed parser
