    id int,
    name text,
    age int,
    score float
);

create table orders_159 (
    id int,
    user_id int,
    amount float,
    status text
);

-- INSERT: provides literal values
insert into users_159 values (1, 'Alice', 30, 95.5);
insert into users_159 values (2, 'Bob', 25, 82.0);
insert into orders_159 values (1, 1, 49.99, 'shipped');

-- SELECT with infix WHERE expressions (operator precedence via infix rule)
select * from users_159 where age > 25 and score >= 90.0;

